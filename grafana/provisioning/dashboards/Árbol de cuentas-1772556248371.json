          "rawSql": "SELECT \r\n  fecha AS time, \r\n  SUM(\r\n    CASE \r\n      WHEN LOWER(tipo) = 'ingreso' THEN monto \r\n      WHEN LOWER(tipo) = 'gasto' THEN -monto \r\n      ELSE 0 \r\n    END\r\n  ) OVER (ORDER BY fecha ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS saldo_acumulado \r\nFROM transacciones \r\nWHERE user_id = ${var_user_id}\r\nORDER BY fecha;",
